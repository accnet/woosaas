# Application
APP_ENV=development
LOG_LEVEL=debug

# Public URLs
API_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
DASHBOARD_URL=http://localhost:3000
DASHBOARD_DEV_PORT=3001
DASHBOARD_DEV_PUBLIC_URL=http://localhost:3001
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080
TRACKER_BASE_URL=http://localhost:3000
ALLOW_INSECURE_PUBLIC_URLS=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# PostgreSQL - Business data
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=woosaas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ClickHouse - Analytics events
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=woosaas
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DEBUG=false

# Redis - Queue, cache, realtime
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6380
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-secure-secret-in-production

# WordPress local plugin target
WP_PLUGIN_PATH=/var/www/site1.local/wp-content/plugins/plugin

# API
PORT=8080
HOST=0.0.0.0

# Dashboard container host port
DASHBOARD_PORT=3000

# Optional integration secret
INTEGRATION_ENCRYPTION_KEY=

# Platform admin bootstrap
PLATFORM_ADMIN_EMAIL=admin@woosaas.com
PLATFORM_ADMIN_PASSWORD=Admin123!
PLATFORM_ADMIN_NAME=Platform Admin
PLATFORM_ADMIN_ROLE=owner

# Worker
WORKER_BATCH_SIZE=1000
WORKER_FLUSH_INTERVAL=2
WORKER_MAX_RETRIES=3
