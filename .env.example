# Application
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug

# PostgreSQL - Business data
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=woosaas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ClickHouse - Analytics events
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=woosaas
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DEBUG=false

# Redis - Queue, cache, realtime
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-secure-secret-in-production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
DASHBOARD_URL=http://localhost:3000

# WordPress local plugin target
WP_PLUGIN_PATH=/var/www/site1.local/wp-content/plugins/plugin

# Host port overrides for Docker Compose
CLICKHOUSE_HTTP_PORT=8123
REDIS_HOST_PORT=6380

# Worker
WORKER_BATCH_SIZE=1000
WORKER_FLUSH_INTERVAL=2
WORKER_MAX_RETRIES=3
